{
  "config_version": "2.0",
  "system_name": "Calendar System — Mitigata Prospecting Engine",
  "credit_budget": {
    "max_credits_per_run": 70,
    "credit_warning_threshold": 55,
    "abort_if_remaining_below": 100
  },
  "defaults": {
    "pocs_per_company": 4,
    "country": "India",
    "enrich_on_create": true
  },
  "segmentation_rules": {
    "startup_sme": {"min_employees": 1, "max_employees": 200, "label": "Startup/SME"},
    "mid_market": {"min_employees": 201, "max_employees": 1000, "label": "Mid-Market"},
    "enterprise": {"min_employees": 1001, "max_employees": null, "label": "Enterprise"}
  },
  "signal_fields": {
    "company_segment": "Startup/SME | Mid-Market | Enterprise — derived from estimated_num_employees",
    "headcount_growth_6m": "organization.organization_headcount_six_month_growth — percentage",
    "headcount_growth_12m": "organization.organization_headcount_twelve_month_growth — percentage",
    "annual_revenue": "organization.organization_revenue — float",
    "latest_funding_stage": "organization.latest_funding_stage — string or null",
    "total_funding": "organization.total_funding — float or null",
    "founded_year": "organization.founded_year — integer",
    "job_change_signal": "true if person.employment_history[0].start_date is within last 6 months",
    "company_website": "organization.website_url or organization.primary_domain",
    "tech_stack": "organization.technology_names — array of strings (top 5 relevant)"
  },
  "pitch_label_rules": {
    "_instructions": "For each contact, pick the TOP 5 Mitigata products/services to recommend for the first call. Start with the industry map, then adjust using segment and title modifiers. The final pitch_label is a comma-separated string of 5 items.",
    "industry_product_map": {
      "financial services": ["Cyber Insurance", "D&O Insurance", "Crime Insurance", "SEBI CSCRF Compliance", "Mitigata Console"],
      "capital markets": ["SEBI CSCRF Compliance", "Cyber Insurance", "D&O Insurance", "VCAP", "Crime Insurance"],
      "venture capital & private equity": ["VCAP", "D&O Insurance", "Cyber Insurance", "SOC 2 Compliance", "Mitigata Console"],
      "investment management": ["VCAP", "D&O Insurance", "Cyber Insurance", "SEBI CSCRF Compliance", "Crime Insurance"],
      "investment banking": ["D&O Insurance", "Cyber Insurance", "Crime Insurance", "SEBI CSCRF Compliance", "Mitigata Console"],
      "insurance": ["Cyber Insurance", "D&O Insurance", "ISO 27001", "Mitigata Console", "Crime Insurance"],
      "hospital & health care": ["Cyber Insurance", "HIPAA/DISHA Compliance", "Mitigata Console", "EDR/Endpoint Security", "D&O Insurance"],
      "pharmaceuticals": ["Cyber Insurance", "CPI (Contaminated Products Insurance)", "D&O Insurance", "ISO 27001", "Mitigata Console"],
      "computer software": ["Cyber Insurance", "Tech E&O", "SOC 2 Compliance", "ISO 27001", "Mitigata Console"],
      "information technology and services": ["Cyber Insurance", "Tech E&O", "SOC 2 Compliance", "Mitigata Console", "ISO 27001"],
      "management consulting": ["Cyber Insurance", "Professional Indemnity", "D&O Insurance", "ISO 27001", "Mitigata Console"],
      "construction": ["CGL", "Workmen Compensation", "Cyber Insurance", "Fire Insurance", "D&O Insurance"],
      "apparel & fashion": ["Cyber Insurance", "CGL", "D&O Insurance", "Fire Insurance", "Mitigata Console"],
      "defense & space": ["Cyber Insurance", "ISO 27001", "SIEM/SOC", "Mitigata Console", "D&O Insurance"],
      "hospitality": ["Cyber Insurance", "CGL", "Fire Insurance", "D&O Insurance", "Mitigata Console"],
      "printing": ["CGL", "Cyber Insurance", "Fire Insurance", "Workmen Compensation", "D&O Insurance"],
      "consumer services": ["Cyber Insurance", "CGL", "D&O Insurance", "DPDPA Compliance", "Mitigata Console"],
      "consumer goods": ["Cyber Insurance", "CPI (Contaminated Products Insurance)", "CGL", "D&O Insurance", "Fire Insurance"],
      "human resources": ["Cyber Insurance", "DPDPA Compliance", "D&O Insurance", "Employee Benefits Insurance", "Mitigata Console"],
      "semiconductors": ["Cyber Insurance", "Tech E&O", "ISO 27001", "D&O Insurance", "Mitigata Console"],
      "legal services": ["Cyber Insurance", "Professional Indemnity", "D&O Insurance", "DPDPA Compliance", "Mitigata Console"],
      "mechanical or industrial engineering": ["Cyber Insurance", "CGL", "Fire Insurance", "Workmen Compensation", "D&O Insurance"],
      "entertainment": ["Media Liability", "Cyber Insurance", "D&O Insurance", "Professional Indemnity", "Mitigata Console"],
      "professional training & coaching": ["Cyber Insurance", "Professional Indemnity", "D&O Insurance", "DPDPA Compliance", "Mitigata Console"],
      "non-profit organization management": ["Cyber Insurance", "D&O Insurance", "CGL", "ISO 27001", "Mitigata Console"],
      "real estate": ["Cyber Insurance", "D&O Insurance", "Fire Insurance", "CGL", "Crime Insurance"],
      "_default": ["Cyber Insurance", "D&O Insurance", "Mitigata Console", "ISO 27001", "Crime Insurance"]
    },
    "segment_modifiers": {
      "Startup/SME": "Prioritize Cyber Insurance + D&O bundle. Add SOC 2 if IT/software. Lead with affordability (Mitigata premium from ₹2-2.5L for 5Cr cover).",
      "Mid-Market": "Prioritize Cyber Insurance standalone. Add ISO 27001. Emphasize Mitigata Console (free with insurance, worth $5000).",
      "Enterprise": "Prioritize Mitigata Console + SIEM/SOC. Lead with RELIQ risk quantification. Emphasize marketplace discounts (30%+ on 500+ products)."
    },
    "title_modifiers": {
      "CEO|Founder|Co-Founder": "Lead with D&O Insurance + Cyber Insurance bundle. Mention VCAP if VC/PE. Emphasize board-level risk quantification.",
      "CIO|CTO|Head of Technology|Head of Engineering|VP Engineering": "Lead with Mitigata Console. Emphasize security products marketplace (EDR, SIEM, WAF). Add SOC 2/ISO.",
      "CISO|Sr. Information Security Manager|Cyber Security Manager|GRC Engineer": "Lead with Cyber Insurance. Emphasize Mitigata Console (attack surface monitoring, dark web, phishing sim). Add VAPT/Pen Testing.",
      "CFO|Director Finance|Head of Finance|Finance Manager|VP Finance|Fund Manager": "Lead with Cyber Insurance (financial loss protection). Quantify risk with RELIQ. Add D&O + Crime Insurance.",
      "Compliance Head|Compliance Officer|Chief Compliance Officer|DPO|Company Secretary|Risk & Compliance Manager|Senior Compliance Officer": "Lead with GRC Automation (ISO 27001/SOC 2/PCI DSS). Add DPDPA/GDPR compliance. Emphasize Mitigata Console GRC module.",
      "IT Manager|Head of IT|Head of IT Infrastructure|System Administrator|Server Administrator|Sr. IT Manager|IT Head": "Lead with Mitigata Console + security products (EDR, Firewall, Email Security). Emphasize marketplace discounts. Add ISO 27001.",
      "COO|Operations Manager|Procurement Manager": "Lead with Cyber Insurance (business interruption cover). Add CGL + Workmen Comp if manufacturing. Emphasize operational resilience."
    }
  },
  "apollo_list_columns": {
    "_description": "These are the data points to capture per contact. Standard Apollo fields sync to HubSpot automatically. Signals and pitch_label are set as HubSpot custom properties after sync.",
    "standard_fields": ["first_name", "last_name", "title", "email", "phone", "organization_name"],
    "company_fields": ["website_url", "industry", "estimated_num_employees", "founded_year"],
    "signal_fields": ["company_segment", "headcount_growth_6m", "headcount_growth_12m", "annual_revenue", "latest_funding_stage", "total_funding", "job_change_signal", "tech_stack_top5"],
    "custom_fields": ["pitch_label", "pod_name", "source_date"]
  },
  "hubspot_custom_properties": {
    "_description": "These custom properties must exist in HubSpot before the routine can populate them. Step 0 of the routine will verify/create them.",
    "contact_properties": [
      {"name": "company_segment", "label": "Company Segment", "type": "enumeration", "options": ["Startup/SME", "Mid-Market", "Enterprise"]},
      {"name": "pitch_label", "label": "Pitch Label", "type": "string", "description": "Top 5 Mitigata products/services to pitch on first call"},
      {"name": "job_change_signal", "label": "Job Change Signal", "type": "enumeration", "options": ["Yes", "No"]},
      {"name": "headcount_growth_6m", "label": "Headcount Growth (6M)", "type": "string"},
      {"name": "headcount_growth_12m", "label": "Headcount Growth (12M)", "type": "string"},
      {"name": "prospecting_source", "label": "Prospecting Source", "type": "string", "description": "Calendar System — auto-prospected"}
    ],
    "company_properties": [
      {"name": "company_segment", "label": "Company Segment", "type": "enumeration", "options": ["Startup/SME", "Mid-Market", "Enterprise"]},
      {"name": "latest_funding_stage", "label": "Latest Funding Stage", "type": "string"},
      {"name": "total_funding", "label": "Total Funding", "type": "string"},
      {"name": "annual_revenue_apollo", "label": "Annual Revenue (Apollo)", "type": "string"},
      {"name": "tech_stack", "label": "Tech Stack", "type": "string"},
      {"name": "headcount_growth_6m", "label": "Headcount Growth (6M)", "type": "string"},
      {"name": "headcount_growth_12m", "label": "Headcount Growth (12M)", "type": "string"},
      {"name": "founded_year_apollo", "label": "Founded Year", "type": "string"}
    ]
