  "pitch_label_generation": {
    "_instructions": "DO NOT use a hardcoded industry-to-product map. Instead, dynamically analyze the company's industry, segment, tech stack, funding stage, and the POC's title to recommend the TOP 5–6 most relevant products from the full product catalog below. The AI must reason about what the company actually needs based on its profile. For example: a pharma manufacturer needs CPI + Cyber Insurance + ISO 27001; a funded SaaS startup needs Tech E&O + SOC 2 + D&O; a hospital needs HIPAA/DISHA + Cyber Insurance + EDR. Always include at least one Insurance product and one non-insurance product (security tool, compliance, or Gordon AI). Output as comma-separated string.",
    "segment_guidance": {
      "Startup/SME": "Prioritize Cyber Insurance + D&O bundle. Add SOC 2 if IT/software. Lead with affordability. Include Gordon AI Attack Surface Monitoring for always-on protection.",
      "Mid-Market": "Prioritize standalone Cyber Insurance. Add ISO 27001 and Mitigata Console. Emphasize marketplace discounts on security tools.",
      "Enterprise": "Prioritize Mitigata Console + SIEM/SOC/XDR. Lead with Gordon AI Cyber Risk Scoring. Emphasize GRC platform and marketplace (30%+ discounts on 500+ products)."
    },
    "title_guidance": {
      "CEO|Founder|Co-Founder|Managing Director": "Lead with D&O Insurance + Cyber Insurance. Mention VCAP if VC/PE. Emphasize board-level risk quantification via Gordon AI.",
      "CIO|CTO|Head of Technology|VP Engineering": "Lead with Mitigata Console and security tools marketplace (EDR, SIEM, WAF). Add SOC 2/ISO.",
      "CISO|Information Security|Cyber Security|GRC": "Lead with Cyber Insurance + Gordon AI (attack surface, dark web monitoring, phishing sim). Add VAPT.",
      "CFO|Finance Director|VP Finance|Fund Manager": "Lead with Cyber Insurance (financial loss protection). Quantify risk with Gordon AI. Add D&O + Crime Insurance.",
      "Compliance|DPO|Company Secretary|Risk Manager|Legal": "Lead with GRC/Compliance (ISO 27001/SOC 2/PCI DSS/DPDPA). Add Gordon AI Compliance Dashboard. Emphasize regulatory automation.",
      "IT Manager|Head of IT|System Administrator|IT Head": "Lead with security tools marketplace (EDR, Firewall, Email Security) + Mitigata Console. Add ISO 27001.",
      "COO|Operations|Procurement": "Lead with Cyber Insurance (business interruption). Add CGL + Workmen Comp if manufacturing. Emphasize operational resilience."
    }
  },
